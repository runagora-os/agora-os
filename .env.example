# ════════════════════════════════════════════
#  AGORA OS — Environment Variables
# ════════════════════════════════════════════

# ── Server ────────────────────────────────
PORT=3001
TICK_MS=800          # ms per simulation tick (800ms = watchable speed)

# ── Database (Postgres) ───────────────────
DATABASE_URL=postgres://localhost:5432/agora_os

# ── Simulation ────────────────────────────
# Same seed = identical history on any machine (replayable, verifiable).
SIM_SEED=agora-genesis

# ── Chronicler — Anthropic (Phase 4) ──────
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model to use for the Chronicler. Defaults to claude-opus-4-5-20251101 if unset.
CHRONICLER_MODEL=claude-opus-4-5-20251101

# ── Chronicler — Twitter/X (Phase 4) ──────
# Create a developer app at: https://developer.twitter.com/
# Required permissions: Read + Write
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Solana (Phase 6) ──────────────────────
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SOLANA_KEYPAIR_PATH=/path/to/keypair.json
